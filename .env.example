# App
APP_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ctodash
REDIS_URL=redis://localhost:6379/0

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=
# Local working-tree clone root used instead of the GitHub API for commit history.
# Repos are discovered by walking this directory and reading their origin remotes.
GITHUB_REPOS_DIR=/Users/vineetdaniel/org_repos

# Jira Cloud
JIRA_SERVER=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=PROJ,TECH

# Observability provider: datadog | newrelic
OBSERVABILITY_PROVIDER=datadog

# Datadog
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# New Relic (configure when ready)
NR_API_KEY=
NR_ACCOUNT_ID=

# PagerDuty / Opsgenie (future)
PAGERDUTY_API_KEY=

# AWS Cost Explorer (future)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Optional: LLM-enhanced strategy narrative (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: LLM-enhanced strategy narrative (Anthropic Claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-fable-5

# Security / operational settings
# Comma-separated list of allowed frontend origins for CORS. Required in production.
ALLOWED_ORIGINS=
# Set to true when the PostgreSQL server requires SSL (recommended in production).
DATABASE_REQUIRE_SSL=false
